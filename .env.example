# ── LLM ──────────────────────────────────────────────────────────────
# Claude API 키
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude 모델 ID
# 사용 가능한 최신 모델 ID는 Anthropic 공식 문서/Console에서 확인
# 예: claude-sonnet-4-6 또는 날짜 suffix 버전
LLM_MODEL=claude-sonnet-4-6

# AI 호출 타임아웃 (초)
LLM_TIMEOUT=30

# LLM에 전달할 상세 설명 최대 길이
DETAIL_TEXT_LIMIT=2000


# ── 크롤링 제한 ──────────────────────────────────────────────────────
# 스토어당 최대 수집 상품 수
MAX_PRODUCTS=10

# 상품 간 최소/최대 요청 지연 (초)
# 개발/시연 MVP 기준. 운영 확장 시 더 보수적으로 조정
REQUEST_DELAY_MIN=0.5
REQUEST_DELAY_MAX=1.5

# 상품 상세 수집 재시도 횟수
CRAWL_RETRY_COUNT=2

# 연속 실패 N회 이상이면 해당 스토어 수집 중단
MAX_CONSECUTIVE_FAILURES=5


# ── Playwright ───────────────────────────────────────────────────────
# 개발 중: false 권장 / 제출·시연 기본 실행: true
PLAYWRIGHT_HEADLESS=true

# 페이지 로딩 타임아웃 (ms)
PLAYWRIGHT_TIMEOUT=30000


# ── 출력 ─────────────────────────────────────────────────────────────
# JSON 결과 저장 디렉토리
OUTPUT_DIR=outputs
